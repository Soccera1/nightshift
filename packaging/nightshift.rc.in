#include <winver.h>

1 ICON "@ICON@"
1 24 "@MANIFEST@"

1 VERSIONINFO
FILEVERSION @VERSION_COMMA@
PRODUCTVERSION @VERSION_COMMA@
FILEFLAGSMASK 0x3fL
FILEFLAGS 0x0L
FILEOS 0x40004L
FILETYPE 0x1L
FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "Night Shift"
            VALUE "FileDescription", "Night Shift SDL fangame"
            VALUE "FileVersion", "@VERSION@"
            VALUE "InternalName", "nightshift"
            VALUE "OriginalFilename", "nightshift.exe"
            VALUE "ProductName", "Night Shift"
            VALUE "ProductVersion", "@VERSION@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
