#include <winver.h>

1 ICON "@ICON@"
1 24 "@MANIFEST@"

101 RCDATA "@PACKAGE_DIR@/nightshift.exe"
102 RCDATA "@PACKAGE_DIR@/SDL2.dll"
103 RCDATA "@PACKAGE_DIR@/README.md"
104 RCDATA "@PACKAGE_DIR@/HOW_TO_PLAY.md"
105 RCDATA "@PACKAGE_DIR@/WINDOWS.txt"
106 RCDATA "@PACKAGE_DIR@/LICENSE"
107 RCDATA "@PACKAGE_DIR@/PACKAGE.txt"

1 VERSIONINFO
FILEVERSION @VERSION_COMMA@
PRODUCTVERSION @VERSION_COMMA@
FILEFLAGSMASK 0x3fL
FILEFLAGS 0x0L
FILEOS 0x40004L
FILETYPE 0x1L
FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "Night Shift"
            VALUE "FileDescription", "Night Shift Setup"
            VALUE "FileVersion", "@VERSION@"
            VALUE "InternalName", "nightshift-setup"
            VALUE "OriginalFilename", "nightshift-@VERSION@-win32-setup.exe"
            VALUE "ProductName", "Night Shift"
            VALUE "ProductVersion", "@VERSION@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
